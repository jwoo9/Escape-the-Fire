{
  "expo": {
    "name": "EmergencyNav",
    "slug": "EmergencyNav",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "emergencynav",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to detect BLE beacons for indoor positioning during emergency evacuations.",
        "NSBluetoothPeripheralUsageDescription": "This app uses Bluetooth to detect BLE beacons for indoor positioning.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to determine your position inside the building for evacuation routing.",
        "NSLocationAlwaysUsageDescription": "This app uses your location to track your position during emergencies.",
        "UIBackgroundModes": ["bluetooth-central"]
      },
      "bundleIdentifier": "com.metinhalac.escapethefire"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.metinhalac.escapethefire"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      ["expo-router", { "origin": "https://escapethefire.app" }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "./plugins/withIBeaconRanging.js"
    ],
    "assetBundlePatterns": ["**/*"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}